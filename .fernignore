# =============================================================================
# .fernignore - Files to preserve during Fern SDK regeneration
# =============================================================================

# Git & Repository Configuration
.gitattributes
.gitignore
.version

# GitHub (workflows, actions, templates, community health files)
.github/

# CI/CD & Security Configuration
.semgrepignore
.shiprc
opslevel.yml

# Project Configuration
phpstan.neon
phpstan.neon.dist
phpstan-baseline.neon
phpstan-management.neon
phpunit.xml
phpunit.xml.dist
psalm.xml.dist
phpdoc.dist.xml
.editorconfig
.php-cs-fixer.dist.php
rector.php
composer.json

# Project Documentation
README.md
EXAMPLES.md
CHANGELOG.md
CHANGELOG.ARCHIVE.md
CONTRIBUTING.md
FAQ.md
LICENSE.md
UPGRADE.md
v9_MIGRATION_GUIDE.md

# Docs & Examples
docs/
examples/

# Core SDK Classes (Auth0 SDK entry point and token handling)
src/Auth0.php
src/Token.php

# Authentication API (hand-written, not generated)
src/API/Authentication.php
src/API/Authentication/
src/API/ClientAbstract.php

# Authentication API modules
src/Configuration/
src/Contract/
src/Event/
src/Exception/
src/Mixins/
src/Mock/
src/Store/
src/Token/
src/Utility/

# Authentication API tests
tests/Pest.php
tests/Data/
tests/Unit/
tests/Utilities/

# Management API Wrapper (allows `use Auth0\SDK\API\Management` imports)
src/API/Management.php

# Management Client Wrapper (domain-based client with automatic token management)
src/API/Management/Wrapper/
