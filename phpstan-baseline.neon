			path: src/Token/Verifier.php

		-
			message: '#^Cannot cast mixed to string\.$#'
			identifier: cast.string
			count: 1
			path: src/Token/Verifier.php

		-
			message: '#^Parameter \#1 \$value of function count expects array\|Countable, mixed given\.$#'
			identifier: argument.type
			count: 1
			path: src/Token/Verifier.php

		-
			message: '#^Trying to invoke mixed but it''s not a callable\.$#'
			identifier: callable.nonCallable
			count: 1
			path: src/Utility/EventDispatcher.php

		-
			message: '#^Parameter \#1 \$headers of method Auth0\\SDK\\Utility\\HttpRequest\:\:withHeaders\(\) expects array\<string, int\|string\>, array\<int\|string\> given\.$#'
			identifier: argument.type
			count: 1
			path: src/Utility/HttpClient.php

		-
			message: '#^Property Auth0\\SDK\\Utility\\HttpClient\:\:\$mockedResponses \(array\<object\>\) does not accept array\<object\>\|null\.$#'
			identifier: assign.propertyType
			count: 1
			path: src/Utility/HttpClient.php

		-
			message: '#^Property Auth0\\SDK\\Utility\\HttpRequest\:\:\$params \(array\<string, int\|string\|null\>\) does not accept array\<int\|string\|null\>\.$#'
			identifier: assign.propertyType
			count: 3
			path: src/Utility/HttpRequest.php

		-
			message: '#^Method Auth0\\SDK\\Utility\\HttpResponsePaginator\:\:count\(\) should return int\<0, max\> but returns int\.$#'
			identifier: return.type
			count: 1
			path: src/Utility/HttpResponsePaginator.php

		-
			message: '#^PHPDoc tag @var with type mixed is not subtype of type int\|string\|null\.$#'
			identifier: varTag.type
			count: 1
			path: src/Utility/HttpResponsePaginator.php

		-
			message: '#^Cannot access offset ''permission_name'' on mixed\.$#'
